---
import { useTranslations, type Lang } from "../i18n";
import Github from "./icons/Github.astro";
import Javascript from "./icons/Javascript.astro";
import MySQL from "./icons/MySQL.astro";
import Php from "./icons/Php.astro";
import React from "./icons/React.astro";
import Sass from "./icons/Sass.astro";
import Firebase from "./icons/Firebase.astro";
import Laravel from "./icons/Laravel.astro";
import Angular from "./icons/Angular.astro";
import Vue from "./icons/Vue.astro";
import Taildwindcss from "./icons/Taildwindcss.astro";

export interface Props {
  lang: Lang;
}
interface ProjectData {
  title: string;
  description: string;
}
const { lang } = Astro.props;
const { t, tArray } = useTranslations(lang);

const TAGS = {
  MYSQL: {
    name: "MySQL",
    class: "bg-[#003159] text-white",
    icon: MySQL,
  },
  PHP: {
    name: "Php",
    class: "bg-[#003159] text-white",
    icon: Php,
  },
  JS: {
    name: "Javascript",
    class: "bg-[#f0db4f] pb-2 pr-3",
    icon: Javascript,
  },
  SASS: {
    name: "Javascript",
    class: "bg-[#FFFF]",
    icon: Sass,
  },
  REACT: {
    name: "React",
    class: "bg-[#4567]",
    icon: React,
  },
  FIREBASE: {
    name: "Firebase",
    class: "bg-[#4567]",
    icon: Firebase,
  },
  LARAVEL: {
    name: "Laravel",
    class: "bg-[#4567]",
    icon: Laravel,
  },
  VUE: {
    name: "Vue",
    class: "bg-[#4567]",
    icon: Vue,
  },
  TAILDWINDCSS: {
    name: "Taildwindcss",
    class: "bg-[#4567]",
    icon: Taildwindcss,
  },
  ANGULAR: {
    name: "Angular",
    class: "bg-[#4567]",
    icon: Angular,
  },
};

const PROJECTS = [
{
    link: "https://github.com/DevJuanDuarte/usuarios_frontend",
    github: "https://github.com/DevJuanDuarte/usuarios_frontend",
    image: "/projects/login.png",
    tags: [TAGS.ANGULAR, TAGS.PHP, TAGS.MYSQL, TAGS.TAILDWINDCSS],
  },
  {
    link: "https://github.com/DevJuanDuarte/libreria_app",
    github: "https://github.com/DevJuanDuarte/libreria_app",
    image: "/projects/libreria.png",
    tags: [TAGS.LARAVEL, TAGS.VUE, TAGS.MYSQL, TAGS.TAILDWINDCSS],
  },
  {
    link: "https://github.com/DevJuanDuarte/Bienes_Raices",
    github: "https://github.com/devjuanduarte/Bienes_Raices",
    image: "/projects/bienesraices.png",
    tags: [TAGS.PHP, TAGS.MYSQL, TAGS.JS, TAGS.SASS],
  },
  {
    link: "https://github.com/DevJuanDuarte/citas-react",
    github: "https://github.com/DevJuanDuarte/citas-react",
    image: "/projects/vetcontrol.png",
    tags: [TAGS.REACT],
  },
];

const projectsData = tArray<ProjectData>("projects");
---

<div class="grid gap-6 p-6 lg:grid-cols-2">
  {PROJECTS.map(({ image, tags, link }, index) => {
    const project = projectsData[index];
    return (
    <div class="flex flex-col max-w-full p-4 border border-gray-200 rounded-lg shadow-lg transition-transform transform hover:scale-105 hover:bg-gray-50 dark:border-gray-700 dark:bg-gray-900 dark:hover:bg-gray-800">
      <img
        loading="lazy"
        class="rounded shadow-lg aspect-video w-full"
        src={image}
        alt={`${t("projectAlt")} ${project?.title}`}
      />

      <div class="flex flex-col mt-4 space-y-4">
        <h3 class="text-2xl font-semibold text-blue-600 dark:text-white">
          {project?.title}
        </h3>
        <p class="text-base font-normal text-gray-700 dark:text-gray-300">
          {project?.description}
        </p>

        <ul class="flex gap-x-2 flex-row mb-2">
      {tags.map((tag) => (
        <li>
          <span
            class={`flex gap-x-4 rounded-full text-xs ${tag.class} size-12 px-2 my-2 border border-gray-300 dark:border-white/10`}
          >
            <tag.icon class="size-7" />
          </span>
        </li>
      ))}
    </ul>

        <a
          href={link}
          target="_blank"
          class="flex items-center justify-center mt-4 px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 border border-gray-200 rounded-lg hover:bg-gray-200 hover:text-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:bg-gray-800 dark:text-gray-300 dark:border-gray-600 dark:hover:text-white dark:hover:bg-gray-700"
        >
          {t("projectButton")}
          <Github class="ml-2 w-5 h-5" />
        </a>
      </div>
    </div>
    );
  })}
</div>
