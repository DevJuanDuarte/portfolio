---
import { useTranslations, type Lang } from "../i18n";

export interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const { t } = useTranslations(lang);
const currentYear = new Date().getFullYear();
const footerText = t("footer").replace("{year}", String(currentYear));
---

<footer class="rounded-lg shadow m-4 bg-gray-50 dark:bg-gray-800">
    <div class="w-full mx-auto max-w-screen-xl p-4 md:items-center md:justify-between text-center">
        <span class="text-sm text-gray-500 dark:text-gray-300">{footerText}</span>
  </div>
</footer>
